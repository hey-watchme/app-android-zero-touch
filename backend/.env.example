# Supabase
SUPABASE_URL=https://qvtlwotzuzbavrzqhyvt.supabase.co
# Backend should use the service role key (never ship this to the Android app).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: anon key (not used by the backend by default)
SUPABASE_KEY=your_anon_key

# AWS
AWS_REGION=ap-southeast-2
S3_BUCKET=watchme-vault

# ASR (Speechmatics)
SPEECHMATICS_API_KEY=your_speechmatics_key
# ASR (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_key
# ASR (Cohere)
COHERE_API_KEY=your_cohere_key
# ASR (Azure Speech Service)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SERVICE_REGION=your_azure_service_region
AZURE_SPEECH_API_VERSION=2025-10-15
AZURE_BATCH_ENABLE_DIARIZATION=true
AZURE_BATCH_MAX_SPEAKERS=4
AZURE_BATCH_POLL_SECONDS=3
AZURE_BATCH_TIMEOUT_SECONDS=600
AZURE_BATCH_TTL_HOURS=24
AZURE_BATCH_S3_URL_EXPIRES_SECONDS=3600

# ASR defaults (optional)
# - Provider/model can also be overridden per-request via /api/transcribe/{id}?provider=...&model=...
# - Language can also be overridden via /api/transcribe/{id}?language=... (supported: ja, en)
# - Azure uses locale-style models such as ja-JP / en-US. If ASR_PROVIDER=azure and ASR_MODEL is omitted,
#   the backend maps ja -> ja-JP and en -> en-US automatically.
ASR_PROVIDER=speechmatics
ASR_MODEL=batch
ASR_LANGUAGE=ja

# LLM
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-5.4-2026-03-05

# Server
PORT=8061
